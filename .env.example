# =============================================================
#  GUÍA DE VARIABLES DE ENTORNO — activos-greenfield
#  NO incluir este archivo en producción con valores reales.
#  Copiar como .env.local (frontend) o .env (backend).
# =============================================================


# ┌─────────────────────────────────────────────────────────┐
# │  BACKEND — Railway                                       │
# │  Configurar en: Railway → Tu servicio → Variables        │
# └─────────────────────────────────────────────────────────┘

# Entorno de ejecución
NODE_ENV=production

# Puerto que Railway asigna automáticamente (no cambiar)
PORT=3001

# ── Base de datos (Red Privada de Railway) ─────────────────
# Railway genera automáticamente estas variables cuando enlazas
# el servicio PostgreSQL a tu backend en el mismo proyecto.
# En la sección "Connect" de tu servicio PostgreSQL verás:
#   - Internal host (solo accesible dentro de Railway): xxx.railway.internal
#   - Internal port: 5432
#
# NUNCA uses el host público (roundhouse.proxy.rlwy.net) en producción,
# ya que expone el puerto 5432 al internet. Usa el host interno:
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# ── CORS ──────────────────────────────────────────────────
# URL de tu frontend en Netlify. Puedes poner varios separados por coma:
ALLOWED_ORIGINS=https://creative-crumble-c034bf.netlify.app
FRONTEND_URL=https://creative-crumble-c034bf.netlify.app
BACKEND_URL=https://activos-greenfield-backend-production.up.railway.app

# ── JWT ────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=activos_greenfield_secret_key_2024_secure

# ── Cloudinary (subida de imágenes) ──────────────────────
CLOUDINARY_CLOUD_NAME=dfkv6g00w
CLOUDINARY_API_KEY=983462731935629
CLOUDINARY_API_SECRET=g5-ZgCQHL_-SP7QKhjSppFwSJKo


# ┌─────────────────────────────────────────────────────────┐
# │  FRONTEND — Netlify                                      │
# │  Configurar en: Netlify → Site → Environment variables  │
# └─────────────────────────────────────────────────────────┘

# URL pública de tu API en Railway (con /api al final)
NEXT_PUBLIC_API_URL=https://activos-greenfield-backend-production.up.railway.app/api

# Entorno (Netlify lo inyecta automáticamente, pero es buena práctica declararlo)
NODE_ENV=production


# ┌─────────────────────────────────────────────────────────┐
# │  GITHUB ACTIONS — Secrets del repositorio               │
# │  Configurar en: GitHub → Repo → Settings → Secrets      │
# └─────────────────────────────────────────────────────────┘

# ── Conexión a PostgreSQL en Railway para pg_dump ─────────
# Usa el host PÚBLICO de Railway (el backup corre fuera de Railway).
# En Railway → PostgreSQL → Connect → "Public URL":
RAILWAY_DB_HOST=roundhouse.proxy.rlwy.net
RAILWAY_DB_PORT=XXXXX          # reemplaza con el puerto público de Railway
RAILWAY_DB_USER=postgres
RAILWAY_DB_PASSWORD=YCCuEWssicKLooacjSgAQtgKcSvQzGDR
RAILWAY_DB_NAME=railway

# ── AWS S3 para almacenar los backups ─────────────────────
# Crea un usuario IAM con permiso mínimo: s3:PutObject en el bucket específico.
# Política IAM mínima recomendada:
#   {
#     "Version": "2012-10-17",
#     "Statement": [{
#       "Effect": "Allow",
#       "Action": ["s3:PutObject"],
#       "Resource": "arn:aws:s3:::TU-BUCKET/backups/*"
#     }]
#   }
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=activos-greenfield-backups


# =============================================================
#  CONFIGURACIÓN DE RED PRIVADA EN RAILWAY
#  (Instrucciones — no es código, es guía paso a paso)
# =============================================================
#
#  Para que el backend se conecte a PostgreSQL por red interna
#  (sin exponer el puerto 5432 al internet):
#
#  1. En Railway, crea un PROYECTO que contenga AMBOS servicios:
#     - Servicio "backend" (Node.js)
#     - Servicio "postgres" (PostgreSQL plugin)
#
#  2. En el servicio "backend", agrega la variable:
#       DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
#     (Railway inyecta ${{Postgres.DATABASE_PRIVATE_URL}} automáticamente
#      si usas "Reference Variable" en la UI — es la forma más segura)
#
#  3. Ve al servicio PostgreSQL → Settings → Networking:
#     - Asegúrate de que "Public Networking" esté DESACTIVADO si no
#       necesitas acceso externo permanente.
#     - Para el backup de GitHub Actions SÍ需要 el puerto público habilitado
#       SOLO durante la ejecución, o usa un túnel SSH / Railway CLI.
#
#  4. Verifica la conexión interna desde tu backend:
#       import { pool } from './config/database.js';
#       pool.query('SELECT NOW()', console.log);
#
# =============================================================
